# Build from the main Dockerfile
FROM localhost/notlinktree:test

# Switch to root for test setup
USER root

# Install test dependencies
RUN apk add --no-cache curl jq

# Copy test scripts
COPY test/docker/healthcheck.sh /test/
COPY test/docker/volume_test.sh /test/
RUN chmod +x /test/*.sh

# Switch back to non-root
USER notlinktree

# Override the entrypoint to run tests instead of the main app
ENTRYPOINT ["/test/volume_test.sh"]
